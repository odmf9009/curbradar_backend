# ============================================================
# CurbRadar Backend — Variables de Entorno
# Copia este archivo: cp .env.example .env
# NUNCA subas el .env a git
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# En producción con Nginx como reverse proxy, el puerto puede ser 3000
# y Nginx escucha en 80/443 y redirige a localhost:3000

# ── MongoDB ───────────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/curbradar
# Atlas (producción):
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/curbradar?retryWrites=true&w=majority

# ── Firebase Admin SDK ────────────────────────────────────────
# (Auth + Storage + FCM — la parte GRATIS que conservamos)
FIREBASE_PROJECT_ID=curbradar-6d8f0
FIREBASE_STORAGE_BUCKET=curbradar-6d8f0.firebasestorage.app

# Opción A — archivo JSON local (para desarrollo)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Opción B — JSON inline (para Railway, Render, VPS sin archivos sensibles)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"curbradar-6d8f0",...}

# ── Google AI (Gemini) ────────────────────────────────────────
# Gemini corre en el BACKEND — nunca en el cliente Flutter
GEMINI_API_KEY=

# ── CORS ──────────────────────────────────────────────────────
# Para producción con dominio:
# ALLOWED_ORIGINS=https://curbradar.tech,https://www.curbradar.tech
# Para desarrollo (acepta cualquier origen):
ALLOWED_ORIGINS=*

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
